{
  "name": "@qtsurfer/lastra",
  "version": "0.9.1",
  "description": "TypeScript reader for the Lastra columnar time series format",
  "license": "Apache-2.0",
  "author": "QTSurfer (https://github.com/QTSurfer)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "apache-arrow": "^21.1.0",
    "fzstd": "^0.1.1"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QTSurfer/lastra-ts.git"
  },
  "bugs": {
    "url": "https://github.com/QTSurfer/lastra-ts/issues"
  },
  "homepage": "https://github.com/QTSurfer/lastra-ts",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "lastra",
    "time-series",
    "columnar",
    "compression",
    "alp",
    "financial-data",
    "iot",
    "binary-format",
    "zstd",
    "typescript"
  ]
}
